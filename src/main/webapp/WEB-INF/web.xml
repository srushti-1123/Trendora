<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Trendora</display-name>

    <!-- Home Servlet -->
    <servlet>
        <servlet-name>HomeController</servlet-name>
        <servlet-class>com.trendora.controller.HomeController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeController</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    
    <!-- User Servlet -->
<servlet>
    <servlet-name>UserController</servlet-name>
    <servlet-class>com.trendora.controller.UserController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>UserController</servlet-name>
    <url-pattern>/user</url-pattern>
</servlet-mapping>

<!-- Login Mapping -->
<servlet-mapping>
    <servlet-name>UserController</servlet-name>
    <url-pattern>/login</url-pattern>
</servlet-mapping>

<!-- Register Mapping -->
<servlet-mapping>
    <servlet-name>UserController</servlet-name>
    <url-pattern>/register</url-pattern>
</servlet-mapping>

<!-- Logout Mapping -->
<servlet-mapping>
    <servlet-name>UserController</servlet-name>
    <url-pattern>/logout</url-pattern>
</servlet-mapping>

<!-- Product Servlet -->
<servlet>
    <servlet-name>ProductController</servlet-name>
    <servlet-class>com.trendora.controller.ProductController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ProductController</servlet-name>
    <url-pattern>/products</url-pattern>
</servlet-mapping>

<!-- Product Detail Servlet -->
<servlet>
    <servlet-name>ProductDetailController</servlet-name>
    <servlet-class>com.trendora.controller.ProductDetailController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ProductDetailController</servlet-name>
    <url-pattern>/product-detail</url-pattern>
</servlet-mapping>

<!-- Cart Servlet -->
<servlet>
    <servlet-name>CartController</servlet-name>
    <servlet-class>com.trendora.controller.CartController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>CartController</servlet-name>
    <url-pattern>/cart</url-pattern>
</servlet-mapping>

<!-- Checkout Servlet -->
<servlet>
    <servlet-name>CheckoutController</servlet-name>
    <servlet-class>com.trendora.controller.CheckoutController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>CheckoutController</servlet-name>
    <url-pattern>/checkout</url-pattern>
</servlet-mapping>
<servlet-mapping>
    <servlet-name>CheckoutController</servlet-name>
    <url-pattern>/payment</url-pattern>
</servlet-mapping>

<!-- Order Confirmation Servlet -->
<servlet>
    <servlet-name>OrderConfirmationController</servlet-name>
    <servlet-class>com.trendora.controller.OrderConfirmationController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>OrderConfirmationController</servlet-name>
    <url-pattern>/order-confirmation</url-pattern>
</servlet-mapping>

<!-- Order Servlet -->
<servlet>
    <servlet-name>OrderController</servlet-name>
    <servlet-class>com.trendora.controller.OrderController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>OrderController</servlet-name>
    <url-pattern>/orders</url-pattern>
</servlet-mapping>
<servlet-mapping>
    <servlet-name>OrderController</servlet-name>
    <url-pattern>/order-detail</url-pattern>
</servlet-mapping>

<!-- Profile Servlet -->
<servlet>
    <servlet-name>ProfileController</servlet-name>
    <servlet-class>com.trendora.controller.ProfileController</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ProfileController</servlet-name>
    <url-pattern>/profile</url-pattern>
</servlet-mapping>

    <!-- Welcome Page -->
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

    <!-- Error Pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/views/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/error.jsp</location>
    </error-page>

</web-app>